# Mandatory Telegram Credentials
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_USER_ID="YOUR_TELEGRAM_CHAT_ID"

# LLM Provider Configuration ("gemini" or "deepseek")
LLM_PROVIDER="gemini"
LLM_API_KEY="YOUR_LLM_API_KEY"

# Optional Customizations (Uncomment to override defaults)
# LLM_MODEL="gemini-1.5-flash"
# LLM_API_URL=""
# CHECK_INTERVAL_MINUTES="5"
# CPU_THRESHOLD_PERCENT="80.0"
# MEMORY_THRESHOLD_PERCENT="80.0"
# DISK_THRESHOLD_PERCENT="85.0"
# DISK_MOUNT_PATH="/host"
# LOG_FILE_PATH="nas-watchdog.jsonl"
# USER_APPROVAL_TIMEOUT_MINUTES="10"
# LLM_TIMEOUT_SECONDS="60"
# WEB_SCRAPER_TIMEOUT_SECONDS="15"
# MAX_SEARCH_RESULTS="6"
# TOP_PROCESSES_LIMIT="15"
